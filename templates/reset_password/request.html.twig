{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            padding: 20px;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            padding: 0;
            max-width: 480px;
            width: 100%;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            animation: slideUp 0.5s ease-out;
            border: 1px solid #e2e8f0;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo {
            display: block;
            text-align: center;
            padding: 40px 40px 20px;
            background: linear-gradient(135deg, #2d8b8b 0%, #1a6b6b 100%);
        }

        .logo img {
            max-width: 180px;
            height: auto;
        }

        .login-main {
            padding: 40px;
        }

        .login-main h2 {
            font-size: 28px;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 10px;
            text-align: center;
        }

        .subtitle {
            font-size: 14px;
            color: #718096;
            text-align: center;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .alert {
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideDown 0.3s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-danger {
            background-color: #fee;
            border-left: 4px solid #e53e3e;
            color: #c53030;
        }

        .alert-danger:before {
            content: "⚠️";
            font-size: 20px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .col-form-label {
            font-weight: 600;
            color: #2d3748;
            margin-bottom: 8px;
            display: block;
            font-size: 14px;
        }

        .form-control {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            background: #f7fafc;
        }

        .form-control:focus {
            outline: none;
            border-color: #2d8b8b;
            background: white;
            box-shadow: 0 0 0 3px rgba(45, 139, 139, 0.1);
        }

        .form-control::placeholder {
            color: #a0aec0;
        }

        .form-help-text {
            display: flex;
            align-items: start;
            gap: 8px;
            padding: 12px 16px;
            background: #f0fdf4;
            border-radius: 8px;
            margin-top: 12px;
            margin-bottom: 25px;
        }

        .form-help-text:before {
            content: "💡";
            font-size: 18px;
            flex-shrink: 0;
        }

        .form-help-text small {
            font-size: 13px;
            color: #166534;
            line-height: 1.5;
        }

        .btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #2d8b8b 0%, #1a6b6b 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(45, 139, 139, 0.4);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .back-to-login {
            text-align: center;
            margin-top: 25px;
            padding-top: 25px;
            border-top: 1px solid #e2e8f0;
        }

        .back-to-login a {
            color: #2d8b8b;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .back-to-login a:hover {
            color: #1a6b6b;
            gap: 8px;
        }

        .icon-wrapper {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            background: linear-gradient(135deg, #2d8b8b 0%, #1a6b6b 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: scaleIn 0.5s ease-out;
        }

        @keyframes scaleIn {
            from {
                transform: scale(0);
            }
            to {
                transform: scale(1);
            }
        }

        .icon-wrapper svg {
            width: 40px;
            height: 40px;
            stroke: white;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            fill: none;
        }

        @media (max-width: 576px) {
            .login-card {
                border-radius: 0;
            }

            .login-main {
                padding: 30px 20px;
            }

            .logo {
                padding: 30px 20px 15px;
            }

            .login-main h2 {
                font-size: 24px;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page-wrapper">
        <div class="container-fluid p-0">
            <div class="row justify-content-center">
                <div class="col-12">
                    <div class="login-card">

                            <div class="login-main">
                                <div class="icon-wrapper">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M19 11H5M12 8L8 12L12 16"></path>
                                        <rect x="3" y="5" width="18" height="14" rx="2" ry="2"></rect>
                                        <polyline points="3,8 12,13 21,8"></polyline>
                                    </svg>
                                </div>

                                <h2>Mot de passe oublié ?</h2>
                                <p class="subtitle">
                                    Pas de problème ! Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
                                </p>

                                {% for flash_error in app.flashes('reset_password_error') %}
                                    <div class="alert alert-danger" role="alert">
                                        {{ flash_error }}
                                    </div>
                                {% endfor %}

                                {{ form_start(requestForm, {'attr': {'class': 'theme-form'}}) }}
                                
                                    <div class="form-group">
                                        
                                            Adresse email
                                        </label>
                                        {{ form_widget(requestForm.email, {
                                            'attr': {
                                                'class': 'form-control',
                                                'placeholder': 'exemple@email.com',
                                                'autocomplete': 'email'
                                            }
                                        }) }}
                                        {{ form_errors(requestForm.email) }}
                                    </div>

                                    <div class="form-help-text">
                                        <small>
                                            Nous vous enverrons un email contenant un lien sécurisé pour réinitialiser votre mot de passe.
                                        </small>
                                    </div>

                                    <button class="btn btn-primary" type="submit">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                            <polyline points="22,6 12,13 2,6"></polyline>
                                        </svg>
                                        Envoyer le lien de réinitialisation
                                    </button>

                                    <div class="back-to-login">
                                        <a href="{{ path('app_login') }}">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                                <polyline points="12 19 5 12 12 5"></polyline>
                                            </svg>
                                            Retour à la connexion
                                        </a>
                                    </div>

                                {{ form_end(requestForm) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Auto-focus sur le champ email
        document.addEventListener('DOMContentLoaded', function() {
            const emailInput = document.querySelector('input[type="email"]');
            if (emailInput) {
                emailInput.focus();
            }
        });
    </script>
{% endblock %}