{% extends 'Vendeur/BO.html.twig' %}

{% block body %}
{{ parent() }}

<div class="page-body">
  <div class="container-fluid">
    <div class="page-title mb-3">
      <h3 class="fw-bold text-primary">Modifier le Profil</h3>
      <hr>
    </div>
  </div>

  <div class="container-fluid">
    <div class="edit-profile">
      <div class="row">
        <div class="col-xl-12">
          {{ form_start(form, {'attr': {'class': 'card p-4 shadow-sm','novalidate':'novalidate'}}) }}

          <div class="card-body">
            <div class="row g-3">

              <div class="col-md-6">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Nom'}}) }}
                <div class="text-danger">{{ form_errors(form.nom) }}</div>
              </div>

              <div class="col-md-6">
                {{ form_label(form.prenom) }}
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Prénom'}}) }}
                <div class="text-danger">{{ form_errors(form.prenom) }}</div>
              </div>

              <div class="col-md-6">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Email'}}) }}
                <div class="text-danger">{{ form_errors(form.email) }}</div>
              </div>

              <div class="col-md-6">
                {{ form_label(form.telephone) }}
                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': 'Téléphone'}}) }}
                <div class="text-danger">{{ form_errors(form.telephone) }}</div>
              </div>

              <div class="col-md-6">
                {{ form_label(form.adresse) }}
                {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Adresse'}}) }}
                <div class="text-danger">{{ form_errors(form.adresse) }}</div>
              </div>

              <div class="col-md-6">
                {{ form_label(form.password) }}
                {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Mot de passe'}}) }}
                <div class="text-danger">{{ form_errors(form.password) }}</div>
              </div>

              <div class="col-md-8">
                {{ form_label(form.photo) }}
                {{ form_widget(form.photo, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger">{{ form_errors(form.photo) }}</div>
                <small class="form-text text-muted">Image actuelle :</small><br>
                <img alt="Photo" 
                     src="{{ vendeur.photo ? asset('uploads/photos/' ~ vendeur.photo) : asset('uploads/default.jpg') }}" 
                     width="100" class="mt-2 rounded">
              </div>

            </div>
          </div>

          <div class="card-footer text-end">
            <button class="btn btn-primary" type="submit">Mettre à jour</button>
          </div>

          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
</div>

{% endblock %}
