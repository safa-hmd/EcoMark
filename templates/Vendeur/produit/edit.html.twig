{% extends 'Vendeur/BO.html.twig' %}

{% block body %}
{{ parent() }}

<div class="page-body">
    <div class="container-fluid">
        <div class="page-title">
            <h3>Modifier le Produit</h3>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-body">
                        {# AJOUT: novalidate #}
                        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}
                        
                        {# AJOUT: Erreurs globales #}
                        {% if not form.vars.valid %}
                            <div class="alert alert-danger mb-4">
                                <h5 class="alert-heading">⚠️ Des erreurs empêchent la soumission :</h5>
                                {{ form_errors(form) }}
                            </div>
                        {% endif %}
                        
                        <div class="row">
                            {# CHAMP NOM PRODUIT #}
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.nomProduit, 'Nom du produit *', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.nomProduit, {
                                    'attr': {
                                        'class': 'form-control' ~ (form.nomProduit.vars.errors|length > 0 ? ' is-invalid' : '')
                                    }
                                }) }}
                                {% if form.nomProduit.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.nomProduit.vars.errors %}
                                            <div class="text-danger small">❌ {{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {# CHAMP PRIX #}
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.prix, 'Prix (€) *', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.prix, {
                                    'attr': {
                                        'class': 'form-control' ~ (form.prix.vars.errors|length > 0 ? ' is-invalid' : '')
                                    }
                                }) }}
                                {% if form.prix.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.prix.vars.errors %}
                                            <div class="text-danger small">❌ {{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {# CHAMP DESCRIPTION #}
                            <div class="col-md-12 mb-3">
                                {{ form_label(form.description, 'Description *', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.description, {
                                    'attr': {
                                        'class': 'form-control' ~ (form.description.vars.errors|length > 0 ? ' is-invalid' : ''),
                                        'rows': 4
                                    }
                                }) }}
                                {% if form.description.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.description.vars.errors %}
                                            <div class="text-danger small">❌ {{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {# CHAMP QUANTITÉ STOCK #}
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.quantiteStock, 'Quantité en stock *', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.quantiteStock, {
                                    'attr': {
                                        'class': 'form-control' ~ (form.quantiteStock.vars.errors|length > 0 ? ' is-invalid' : '')
                                    }
                                }) }}
                                {% if form.quantiteStock.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.quantiteStock.vars.errors %}
                                            <div class="text-danger small">❌ {{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {# CHAMP ÉTAT PRODUIT #}
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.etatProduit, 'État du produit *', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.etatProduit, {
                                    'attr': {
                                        'class': 'form-control' ~ (form.etatProduit.vars.errors|length > 0 ? ' is-invalid' : '')
                                    }
                                }) }}
                                {% if form.etatProduit.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.etatProduit.vars.errors %}
                                            <div class="text-danger small">❌ {{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {# CHAMP POINT RECYCLAGE #}
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.pointRecyclage, 'Point de recyclage', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.pointRecyclage, {
                                    'attr': {
                                        'class': 'form-control' ~ (form.pointRecyclage.vars.errors|length > 0 ? ' is-invalid' : '')
                                    }
                                }) }}
                                {% if form.pointRecyclage.vars.errors|length > 0 %}
                                    <div class="invalid-feedback d-block">
                                        {% for error in form.pointRecyclage.vars.errors %}
                                            <div class="text-danger small">❌ {{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <div class="form-text text-muted">Optionnel</div>
                            </div>
                            
                            {# CHAMP PHOTO #}
                            <div class="col-md-12 mb-3">
                                <div class="mb-3">
                                    {{ form_label(form.photo, 'Photo du produit', {'label_attr': {'class': 'form-label'}}) }}
                                    
                                    <!-- Affichage de la photo actuelle -->
                                    {% if produit.photo %}
                                        <div class="mb-2">
                                            <p><strong>Photo actuelle :</strong></p>
                                            <img src="{{ asset('uploads/produits/' ~ produit.photo) }}" 
                                                 alt="{{ produit.nomProduit }}" 
                                                 class="img-thumbnail" 
                                                 style="max-width: 200px;">
                                            <p class="text-muted mt-1">Nom du fichier: {{ produit.photo }}</p>
                                        </div>
                                    {% else %}
                                        <div class="mb-2">
                                            <p class="text-muted">Aucune photo actuellement</p>
                                        </div>
                                    {% endif %}
                                    
                                    {{ form_widget(form.photo, {
                                        'attr': {
                                            'class': 'form-control' ~ (form.photo.vars.errors|length > 0 ? ' is-invalid' : '')
                                        }
                                    }) }}
                                    
                                    {# AJOUT: Affichage des erreurs photo #}
                                    {% if form.photo.vars.errors|length > 0 %}
                                        <div class="invalid-feedback d-block">
                                            {% for error in form.photo.vars.errors %}
                                                <div class="text-danger small">❌ {{ error.message }}</div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                    
                                    <div class="form-text text-muted">
                                        Laissez vide pour conserver la photo actuelle. Formats acceptés: JPG, PNG, GIF, JPEG. Taille maximale: 1MB
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4">
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-save"></i> Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_vendeur_produit_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour à la liste
                            </a>
                            <a href="{{ path('app_vendeur_produit_show', {'id': produit.id}) }}" class="btn btn-info">
                                <i class="fas fa-eye"></i> Voir les détails
                            </a>
                        </div>
                        
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.is-invalid {
    border-color: #dc3545 !important;
}
.text-danger.small {
    font-size: 0.875em;
    margin-top: 0.25rem;
}
.form-label:after {
    content: " *";
    color: #dc3545;
}
</style>
{% endblock %}