{# templates/vendeur/alertes/error.html.twig #}
{% extends 'Vendeur/BO.html.twig' %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Erreur</h4>
                </div>
                <div class="card-body">
                    <h5 class="text-danger">{{ message|default('Une erreur est survenue') }}</h5>
                    
                    <div class="mt-4">
                        <a href="{{ path('app_vendeur_alertes_index') }}" class="btn btn-primary">
                            <i class="fas fa-arrow-left"></i> Retour au dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}