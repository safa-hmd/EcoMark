                    <script>
                    Swal.fire({
                        icon: '{{ label == "success" ? "success" : (label == "warning" ? "warning" : "info") }}',
                        title: '{{ message }}',
                        showConfirmButton: false,
                        timer: 2000
                            });
                    </script>
                {% endfor %}
