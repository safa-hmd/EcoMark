<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 14px;
            padding: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo {
            width: 120px;
            margin-bottom: 10px;
        }

        .app-name {
            font-size: 22px;
            font-weight: bold;
            color: #2c3e50;
        }

        .section-title {
            font-size: 18px;
            margin-top: 20px;
            margin-bottom: 10px;
            color: #2980b9;
        }

        .content-box {
            border: 1px solid #ccc;
            padding: 15px;
            border-radius: 8px;
            background: #f9f9f9;
        }
    </style>
</head>

<body>

<div class="header">
    {% if logoBase64 %}
        <img src="{{ logoBase64 }}" class="logo" alt="Logo">
    {% endif %}
    <div class="app-name">EcoMarket - Réclamation</div>
</div>

<h2 class="section-title">Détails de la Réclamation</h2>

<div class="content-box">
    <p><strong>ID :</strong> {{ reclamation.id }}</p>
    <p><strong>Objet :</strong> {{ reclamation.objet }}</p>
    <p><strong>Description :</strong> {{ reclamation.description }}</p>
    <p><strong>Date :</strong> {{ reclamation.dateCreation|date('d/m/Y') }}</p>
    <p><strong>Statut :</strong> {{ reclamation.statut }}</p>
    <p><strong>Client :</strong> {{ reclamation.client.email }}</p>
</div>

</body>
</html>