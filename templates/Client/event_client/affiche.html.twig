{% extends 'Client/FO.html.twig' %}

{% block body %}
<link rel="stylesheet" href="{{ asset('FO/styleclient.css') }}">

<h1 class="page-title">Participation enregistrée avec succès</h1>

<h4 class="page-subtitle">Voila la Liste de Vos Participations</h4>

<div class="table-container">
    <table class="eco-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Événement</th>
                <th>Date de participation</th>
                <th>Statut</th>
                <th>Annuler</th>
            </tr>
        </thead>

        <tbody>
        {% for participation in participations %}
            <tr>
                <td data-label="ID">{{ participation.id }}</td>
                <td data-label="Événement">{{ participation.evenement.titre }}</td>
                <td data-label="Date">{{ participation.dateParticipation|date('Y-m-d H:i') }}</td>
                <td data-label="Statut">{{ participation.statut }}</td>
                <td data-label="Annuler">
                    {% if participation.statut != 'annulee' %}
                        <a href="{{ path('client_cancel_participation', {id: participation.id}) }}"
                           class="btn-green small-btn">
                            Annuler
                        </a>
                    {% else %}
                        <span class="badge bg-secondary">Déjà annulée</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" style="text-align:center;">Aucune participation trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>

    </table>
</div>

<div style="text-align:center; margin-top:20px;">
    <a href="{{ path('client_affiche_evenements') }}" class="btn-green">Retour à la liste</a>
</div>

{% endblock %}
