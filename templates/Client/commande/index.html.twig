{% extends 'Client/FO.html.twig' %}

{% block title %}Mes Commandes{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Mes Commandes</h1>

        {# ✅ Affichage des messages flash #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>N° Commande</th>
                        <th>Date</th>
                        <th>Statut</th>
                        {# ✅ MODIFIÉ : Client → Nom du Client #}
                        <th>Client</th>
                        <th>Montant Total</th>
                        <th>Produits</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for commande in commandes %}
                    <tr>
                        <td><strong>#{{ commande.id }}</strong></td>
                        <td>{{ commande.dateCommande ? commande.dateCommande|date('d/m/Y à H:i') : 'N/A' }}</td>
                        <td>
                            {# ✅ Badge avec couleur selon le statut #}
                            {% if commande.statut == 'en_attente' %}
                                <span class="badge bg-warning text-dark">En attente</span>
                            {% elseif commande.statut == 'en_cours' %}
                                <span class="badge bg-info">En cours</span>
                            {% elseif commande.statut == 'expediee' %}
                                <span class="badge bg-primary">Expédiée</span>
                            {% elseif commande.statut == 'livree' %}
                                <span class="badge bg-success">Livrée</span>
                            {% elseif commande.statut == 'annulee' %}
                                <span class="badge bg-danger">Annulée</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ commande.statut }}</span>
                            {% endif %}
                        </td>
                        {# ✅ MODIFICATION PRINCIPALE : Afficher le nom de l'utilisateur au lieu de commande.client #}
                        <td>
                            {% if commande.user %}
                                {{ commande.user.nom }} {{ commande.user.prenom }}
                            {% else %}
                                <em class="text-muted">Non renseigné</em>
                            {% endif %}
                        </td>
                        <td><strong>{{ commande.montantTotal|number_format(2, ',', ' ') }} €</strong></td>
                        <td>
                            {% if commande.produits %}
                                {{ commande.produits|length > 50 ? commande.produits|slice(0, 50) ~ '...' : commande.produits }}
                            {% else %}
                                <em class="text-muted">Aucun produit</em>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_commande_show', {'id': commande.id}) }}" class="btn btn-sm btn-info" title="Voir les détails">
                                    <i class="bi bi-eye"></i> Détails
                                </a>
                                <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn btn-sm btn-warning" title="Modifier">
                                    <i class="bi bi-pencil"></i> Modifier
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-4">
                            <p class="text-muted mb-3">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i><br>
                                Vous n'avez aucune commande pour le moment.
                            </p>
                            <a href="{{ path('app_commande_new') }}" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Créer ma première commande
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {% if commandes|length > 0 %}
            <div class="mt-3">
                <a href="{{ path('app_commande_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Nouvelle Commande
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}