{% extends 'Client/FO.html.twig' %}

{% block body %}
<!-- PAGE TITLE AREA START -->
<div class="ltn__page-title-area text-center bg-overlay-white-30 bg-image" data-bg="img/bg/14.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="page-title-inner">
                    <h1 class="page-title">{{ produit.nomProduit }}</h1>
                    <div class="ltn__breadcrumb-list">
                        <ul>
                            <li><a href="{{ path('client_home') }}">Accueil</a></li>
                            <li><a href="{{ path('app_client_produit_index') }}">Produits</a></li>
                            <li>Détails</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- PAGE TITLE AREA END -->

<!-- PRODUCT DETAILS AREA START -->
<div class="ltn__product-area ltn__product-gutter mb-100">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="product-img">
                    {% if produit.photo %}
                        <img src="{{ asset('uploads/produits/' ~ produit.photo) }}" 
                             alt="{{ produit.nomProduit }}" 
                             class="img-fluid rounded">
                    {% else %}
                        <div class="no-photo-placeholder rounded" 
                             style="width: 100%; height: 300px; 
                                    background: linear-gradient(135deg, #38b2ac 0%, #319795 100%); 
                                    display: flex; align-items: center; justify-content: center; 
                                    color: white; border: 1px solid #e2e8f0;">
                            <div class="text-center">
                                <i class="fas fa-leaf" style="font-size: 3rem; margin-bottom: 15px; opacity: 0.8;"></i>
                                <h5 class="fw-bold">PRODUIT ÉCOLOGIQUE</h5>
                                <p class="mb-0" style="opacity: 0.8;">Image non disponible</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
            <div class="col-lg-6">
                <div class="product-info">
                    <h1>{{ produit.nomProduit }}</h1>
                    <div class="product-price">
                        <h2 class="text-success">{{ produit.prix }} €</h2>
                    </div>
                    <div class="product-description">
                        <p>{{ produit.description }}</p>
                    </div>
                    <div class="product-meta">
                        <ul>
                            <li><strong>Quantité en stock:</strong> {{ produit.quantiteStock }}</li>
                            <li><strong>État:</strong> 
                                <span class="badge bg-{{ produit.etatProduit == 'Disponible' ? 'success' : 'warning' }}">
                                    {{ produit.etatProduit }}
                                </span>
                            </li>
                            <li><strong>Date d'ajout:</strong> {{ produit.dateAjout ? produit.dateAjout|date('d/m/Y') : '' }}</li>
                            {% if produit.pointRecyclage %}
                            <li><strong>Point de recyclage:</strong> {{ produit.pointRecyclage.nomPoint }}</li>
                            {% endif %}
                        </ul>
                    </div>
                    <div class="product-actions mt-4">
                        {% if produit.quantiteStock > 0 and produit.etatProduit == 'Disponible' %}
                            <form action="{{ path('app_client_achat_acheter', {'id': produit.id}) }}" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-shopping-cart"></i> Acheter maintenant
                                </button>
                            </form>
                        {% else %}
                            <button class="btn btn-secondary btn-lg" disabled>
                                <i class="fas fa-times-circle"></i> Produit indisponible
                            </button>
                        {% endif %}
                        <a href="{{ path('app_client_produit_index') }}" class="btn btn-outline-secondary">Retour aux produits</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- PRODUCT DETAILS AREA END -->
{% endblock %}