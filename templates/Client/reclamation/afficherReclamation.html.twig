{% extends 'Client/FO.html.twig' %}

{% block title %}EcoMarket - Réclamations{% endblock %}

{% block body %}

{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ type }} mt-3 text-center">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}
<style>
    .reclamation-list-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 70vh;
        padding: 20px;
    }

    .reclamation-card {
        width: 100%;
        max-width: 600px;
        background: #fff;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 10px;
        position: relative;
    }

    .reclamation-card h5 {
        margin-bottom: 10px;
        font-weight: bold;
    }

    .reclamation-card p {
        margin-bottom: 5px;
    }

    .reclamation-card .date {
        font-size: 0.85rem;
        color: #888;
    }

    .reclamation-card .actions {
        position: absolute;
        top: 20px;
        right: 20px;
    }

    .reclamation-card .actions a {
        margin-left: 5px;
        padding: 5px 10px;
        font-size: 0.8rem;
        border-radius: 5px;
        text-decoration: none;
        color: #fff;
    }

    .btn-detail { background-color: #17a2b8; }
    .btn-modifier { background-color: #ffc107; }
    .btn-supprimer { background-color: #dc3545; }
</style>

<div class="reclamation-list-wrapper">
    <h2 class="title-2 text-center mb-4">Liste des Réclamations</h2>




    {% for reclamation in reclamations %}
        <div class="reclamation-card">
            <h5>{{ reclamation.Objet }}</h5>
            <p>{{ reclamation.description }}</p>
                        <p>{{ reclamation.statut }}</p>

            <p class="date">Créée le: {{ reclamation.dateCreation|date('d/m/Y H:i') }}</p>
           {% if reclamation.yes %}
    <p class="reponse">
        Réponse : {{ reclamation.yes.Contenu }} <br>
        <small class="text-muted">
            Date de réponse : {{ reclamation.yes.dateCreation ? reclamation.yes.dateCreation|date('d/m/Y H:i') : 'Non défini' }}
        </small>
    </p>
{% else %}
    <p class="reponse text-warning">Pas encore de réponse</p>
{% endif %}


            <div class="actions">
             <a href="{{ path('reclamation_modifierRec', {'ii': reclamation.id}) }}" class="btn-modifier">Modifier</a>
             <a href="{{ path('reclamation_det', {'ii': reclamation.id}) }}" class="btn-detail">Détails</a>
            <a href="{{ path('reclamation_supprimerReclamation', {'ii': reclamation.id}) }}" class="btn-supprimer" 
                   onclick="return confirm('Voulez-vous vraiment supprimer cette réclamation ?');">Supprimer</a>
            </div>
        </div>
    {% else %}
        <p>Aucune réclamation trouvée.</p>
    {% endfor %}
</div>
<div class="pagination-wrapper mt-4">
    {{ knp_pagination_render(reclamations) }}
</div>


{% endblock %}

