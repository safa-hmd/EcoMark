{% extends 'Client/FO.html.twig' %}

{% block body %}
{{ parent() }}

<div class="tab-pane fade show active" id="liton_tab_1_5">
    <div class="ltn__myaccount-tab-content-inner">
        <h3 class="mb-4 text-center">Modifier votre profil</h3>

        <div class="ltn__product-tab-area">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                       {{ form_start(form, {'attr': {'novalidate':'novalidate'}}) }}

                        <!-- Photo de profil -->
                        <div class="text-center mb-4">
                            <img src="{{ client.photo ? asset('uploads/photos/' ~ client.photo) : asset('uploads/default.jpg') }}" 
                                 alt="Photo" class="rounded-circle" width="120">
                        </div>

                        <!-- Nom & Prénom -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_label(form.nom, 'Nom') }}
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Nom'}}) }}
                                <div class="text-danger">{{ form_errors(form.nom) }}</div>
                            </div>
                            <div class="col-md-6">
                                {{ form_label(form.prenom, 'Prénom') }}
                                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Prénom'}}) }}
                                <div class="text-danger">{{ form_errors(form.prenom) }}</div>
                            </div>
                        </div>

                        <!-- Email & Adresse -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_label(form.email, 'Email') }}
                                {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Email'}}) }}
                                <div class="text-danger">{{ form_errors(form.email) }}</div>
                            </div>
                            <div class="col-md-6">
                                {{ form_label(form.adresse, 'Adresse') }}
                                {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Adresse'}}) }}
                                <div class="text-danger">{{ form_errors(form.adresse) }}</div>
                            </div>
                        </div>

                        <!-- Téléphone & Changer la photo -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_label(form.telephone, 'Téléphone') }}
                                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': 'Téléphone'}}) }}
                                <div class="text-danger">{{ form_errors(form.telephone) }}</div>
                            </div>
                            <div class="col-md-6">
                                {{ form_label(form.photo, 'Changer la photo') }}
                                {{ form_widget(form.photo, {'attr': {'class': 'form-control'}}) }}
                                <div class="text-danger">{{ form_errors(form.photo) }}</div>
                            </div>
                        </div>

                        <!-- Mot de passe -->
                        <fieldset class="mb-3 p-3 border rounded">
                            <legend class="small mb-3">Changer le mot de passe</legend>
                            <div class="row">
                                <div class="col-md-6">
                                     {{ form_label(form.password, 'Mot de passe') }}
                                     {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Nouveau mot de passe'}}) }}
                                     <div class="text-danger">{{ form_errors(form.password) }}</div>
                                </div>
                            </div>
                        </fieldset>

                        <!-- Bouton Enregistrer -->
                        <div class="text-center mt-4">
                            <button type="submit" class="btn theme-btn-1 btn-effect-1 text-uppercase px-5">
                                Enregistrer les modifications
                            </button>
                        </div>   
                      {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
