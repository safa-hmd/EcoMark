{% extends 'Admin/BO.html.twig' %}

{% block title %}Gestion des Livraisons{% endblock %}

{% block body %}
{{ parent() }}

<div class="container-fluid mt-4">
    <div class="page-header mb-4">
        <h1 class="display-5">📦 Gestion des Livraisons</h1>
        <p class="text-muted">Liste complète des livraisons</p>
    </div>

    {# Messages flash #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-truck"></i> Liste des Livraisons
            </h5>

            {# ✅ BOUTONS AMÉLIORÉS #}
            <div class="d-flex gap-2">
                <a href="{{ path('admin_stats') }}"
                   class="btn btn-sm btn-stats">
                    <i class="bi bi-bar-chart-line"></i> Statistiques
                </a>

                <a href="{{ path('app_livraison_new') }}"
                   class="btn btn-sm btn-new">
                    <i class="bi bi-plus-circle"></i> Nouvelle Livraison
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>N° Livraison</th>
                            <th>N° Commande</th>
                            <th>Client</th>
                            <th>Adresse</th>
                            <th>Date de Livraison</th>
                            <th>Statut</th>
                            <th>Transporteur</th>
                            <th>N° Suivi</th>
                            <th>Frais</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for livraison in livraisons %}
                        <tr>
                            <td><strong>#{{ livraison.id }}</strong></td>

                            <td>
                                {% if livraison.commande %}
                                    <span class="badge bg-info">Commande #{{ livraison.commande.id }}</span>
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>

                            <td>
                                {% if livraison.commande and livraison.commande.user %}
                                    <strong>{{ livraison.commande.user.nom }} {{ livraison.commande.user.prenom }}</strong><br>
                                    <small class="text-muted">{{ livraison.commande.user.email }}</small>
                                {% else %}
                                    <span class="text-muted">Client inconnu</span>
                                {% endif %}
                            </td>

                            <td class="text-truncate" style="max-width:200px">
                                📍 {{ livraison.adresse }}
                            </td>

                            <td>{{ livraison.dateLivraison|date('d/m/Y') }}</td>

                            <td>
                                <span class="badge bg-success">Expédiée</span>
                            </td>

                            <td>🚛 {{ livraison.transporteur }}</td>

                            <td><code>{{ livraison.numeroSuivi }}</code></td>

                            <td><strong>{{ livraison.fraisLivraison|number_format(2, ',', ' ') }} €</strong></td>

                            <td class="text-center">
                                <a href="{{ path('app_livraison_show', {'id': livraison.id}) }}"
                                   class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_livraison_edit', {'id': livraison.id}) }}"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# ===== STYLES BOUTONS ===== #}
<style>
.btn-stats {
    background: #16a085;
    color: #fff;
    border-radius: 20px;
    padding: 6px 14px;
    font-weight: 600;
}
.btn-stats:hover {
    background: #138d75;
    color: #fff;
}

.btn-new {
    background: #4c84ff;
    color: #fff;
    border-radius: 20px;
    padding: 6px 14px;
    font-weight: 600;
}
.btn-new:hover {
    background: #3b6fe0;
    color: #fff;
}
</style>

{% endblock %}
