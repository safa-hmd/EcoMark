{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
    body {
        background: #f2f5f9;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .dashboard {
        max-width: 1300px;
        margin: 40px auto;
        padding: 20px;
    }

    .title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 25px;
        color: #1b1c1f;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .kpi-card {
        padding: 20px;
        background: white;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 1px solid #ececec;
    }

    .kpi-title {
        font-size: 13px;
        font-weight: 600;
        color: #7a7a7a;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .kpi-value {
        font-size: 26px;
        margin-top: 10px;
        font-weight: 700;
        color: #333;
    }

    .kpi-sub {
        font-size: 12px;
        color: #8a8a8a;
        margin-top: 4px;
    }

    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
    }

    .chart-box {
        background: white;
        padding: 20px;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 1px solid #ececec;
    }

    .chart-title {
        font-size: 18px;
        margin-bottom: 15px;
        font-weight: 600;
        color: #333;
    }

    .chart-subtitle {
        font-size: 13px;
        color: #8a8a8a;
        margin-bottom: 10px;
    }

    @media (max-width: 992px) {
        .kpi-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .charts-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">

    <div class="title">📊 Tableau de bord des commandes</div>

    {# === KPI CALCULS === #}
    {% set totalRevenue = 0 %}
    {% for r in revenues %}
        {% set totalRevenue = totalRevenue + r.total %}
    {% endfor %}

    {# === KPI CARDS === #}
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-title">Total commandes</div>
            <div class="kpi-value">{{ stats|length }}</div>
            <div class="kpi-sub">Toutes périodes confondues</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-title">Revenus totaux (€)</div>
            <div class="kpi-value">{{ totalRevenue|number_format(2, '.', ' ') }}</div>
            <div class="kpi-sub">Somme des montants payés</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-title">Méthodes de paiement</div>
            <div class="kpi-value">{{ paiements|length }}</div>
            <div class="kpi-sub">Types utilisés</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-title">Mois actifs</div>
            <div class="kpi-value">
                {{ stats|column('month')|reduce((v,m)=> m in v ? v : v|merge([m]), [])|length }}
            </div>
            <div class="kpi-sub">Mois avec commandes</div>
        </div>
    </div>

    {# === CHARTS === #}
    <div class="charts-grid">
        <div class="chart-box">
            <div class="chart-title">📅 Commandes par mois</div>
            <div class="chart-subtitle">Évolution du volume</div>
            <canvas id="chartOrders"></canvas>
        </div>

        <div class="chart-box">
            <div class="chart-title">💳 Méthodes de paiement</div>
            <div class="chart-subtitle">Répartition des commandes</div>
            <canvas id="chartPaiement"></canvas>
        </div>
    </div>

    <div class="chart-box" style="margin-top:20px;">
        <div class="chart-title">💶 Revenus mensuels (€)</div>
        <div class="chart-subtitle">Chiffre d’affaires</div>
        <canvas id="chartRevenue"></canvas>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const months  = {{ stats|column('month')|json_encode|raw }};
    const counts  = {{ stats|column('count')|json_encode|raw }};
    const revMonths = {{ revenues|column('month')|json_encode|raw }};
    const totals = {{ revenues|column('total')|json_encode|raw }};
    const paiements = {{ paiements|column('methode')|json_encode|raw }};
    const paiementsCount = {{ paiements|column('total')|json_encode|raw }};

    const monthNames = ["Jan","Fév","Mar","Avr","Mai","Jun","Jul","Aoû","Sep","Oct","Nov","Déc"];

    new Chart(chartOrders, {
        type: 'bar',
        data: {
            labels: months.map(m => monthNames[m-1]),
            datasets: [{
                label: 'Commandes',
                data: counts,
                backgroundColor: '#4c84ff',
                borderRadius: 10
            }]
        }
    });

    new Chart(chartRevenue, {
        type: 'line',
        data: {
            labels: revMonths.map(m => monthNames[m-1]),
            datasets: [{
                label: 'Revenus (€)',
                data: totals,
                borderColor: '#00b894',
                backgroundColor: 'rgba(0,184,148,0.2)',
                fill: true
            }]
        }
    });

    new Chart(chartPaiement, {
        type: 'doughnut',
        data: {
            labels: paiements.map(p => p.replace('_',' ').toUpperCase()),
            datasets: [{
                data: paiementsCount,
                backgroundColor: ['#3498db','#9b59b6','#f1c40f','#2ecc71']
            }]
        },
        options: {
            cutout: '60%',
            plugins: { legend: { position: 'bottom' } }
        }
    });
</script>
{% endblock %}
