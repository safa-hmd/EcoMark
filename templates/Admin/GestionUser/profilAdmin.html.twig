{% extends 'Admin/BO.html.twig' %}

{% block body %}
{{ parent() }}



<div class="page-body">
  <div class="container-fluid">

    <!-- Titre -->
    <div class="page-title mb-3">
      <h2 class="fw-bold text-primary ">Profil Administrateur</h2>
      <hr>
    </div>

    <div class="user-profile">
      <div class="card shadow-lg border-0 profile-card">

        <!-- HEADER AVEC PHOTO + NOM -->
        <div class="profile-header text-center">
          <img 
            src="{{ admin.photo ? asset('uploads/photos/' ~ admin.photo) : asset('uploads/default.jpg') }}"
            alt="Photo"
            class="rounded-circle shadow-lg mb-3"
            width="130"
          >

          <h2 class="fw-bold mb-1">{{ admin.nom }} {{ admin.prenom }}</h2>
          <p class="mb-0 opacity-75">Administrateur</p>
          <h4 class="fw-bold mb-1">{{ admin.id }}</h4>
        </div>

        <!-- INFORMATIONS -->
        <div class="card-body p-5">

          <h4 class="fw-semibold mb-4 text-primary">Informations personnelles</h4>

          <div class="row g-4">

            <div class="col-md-4">
              <div class="p-3 info-box shadow-sm">
                <h6 class="fw-bold text-secondary">Email</h6>
                <p class="mb-0">{{ admin.email }}</p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="p-3 info-box shadow-sm">
                <h6 class="fw-bold text-secondary">Adresse</h6>
                <p class="mb-0">{{ admin.adresse }}</p>
              </div>
            </div>

            <div class="col-md-4">
              <div class="p-3 info-box shadow-sm">
                <h6 class="fw-bold text-secondary">Téléphone</h6>
                <p class="mb-0">{{ admin.telephone }}</p>
              </div>
            </div>

          </div>

          <hr class="my-4">

          <!-- BOUTON SUPPRIMER -->
          <div class="text-center">
            <form method="post"
                  action="{{ path('profilAdmin_delete', {'id': admin.id}) }}">
              <input type="hidden" name="_token" value="{{ csrf_token('delete-profil' ~ admin.id) }}">

              <button class="btn btn-danger px-4 py-2 rounded-3 shadow-sm fw-bold">
                Supprimer le profil
              </button>
            </form>
          </div>

        </div>

      </div>
    </div>

  </div>
</div>



<style>
    .profile-card {
        border-radius: 20px;
        overflow: hidden;
        background: white;
    }

    .profile-header {
        background: linear-gradient(135deg, #707976ff, #7e7e7eff); /* Vert moderne */
        padding: 40px 20px;
        color: white;
    }

    .profile-header img {
        border: 4px solid rgba(255, 255, 255, 0.7);
    }

    .info-box {
        border-radius: 15px;
        background: #f7f9fc;
        transition: 0.3s;
    }

    .info-box:hover {
        background: #eef4f1;
        transform: translateY(-3px);
    }

    .btn-danger {
        background: #e63946 !important;
        border: none;
        transition: 0.3s;
    }

    .btn-danger:hover {
        background: #c62839 !important;
        transform: translateY(-2px);
    }
</style>

{% endblock %}
