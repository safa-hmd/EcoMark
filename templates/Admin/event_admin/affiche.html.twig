{% extends 'Admin/BO.html.twig' %}

{% block body %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('BO/styleadmin.css') }}">
{% endblock %}

{{ parent() }}

<h1 class="mt-3">Liste des événements</h1>

<h2 class="mt-3">Chercher un événement</h2>

<form id="search-form" method="get" action="{{ path('affiche_admin') }}" class="mb-4" style="max-width:400px;">
    <input id="search-input" type="text" name="search" class="form-control"
           placeholder="Rechercher un événement..."
           value="{{ search }}" />
</form>

<div id="events-container">
    {% include 'Admin/event_admin/events_list.html.twig' %}
</div>

<script>
// Empêche le rechargement de la page quand on appuie sur ENTER
document.getElementById('search-form').addEventListener('submit', function(e) {
    e.preventDefault();
});

// Recherche dynamique au fur et à mesure de la frappe
document.getElementById('search-input').addEventListener('keyup', function () {
    let value = this.value;

    fetch('{{ path('search_ajax') }}?search=' + encodeURIComponent(value))
        .then(response => response.text())
        .then(html => {
            document.getElementById('events-container').innerHTML = html;
        });
});
</script>


<div class="action-container">
    <a href="{{ path('admin_evenement_ajout') }}" class="btn btn-secondary">
        Ajouter un événement
    </a>

    <a href="{{ path('admin_participations') }}" class="btn btn-secondary">
        Liste des participations
    </a>
</div>

{% endblock %}
